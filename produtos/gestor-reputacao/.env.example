# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Business Profile (preenchido pelo oauth_setup.py) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCOUNT_NAME=accounts/123456789
GOOGLE_LOCATION_NAME=accounts/123456789/locations/987654321

# ── Negócio do cliente ────────────────────────────────────────────────────────
BUSINESS_NAME=Nome do Negócio
BUSINESS_TYPE=salão de beleza        # ex: restaurante, clínica, barbearia
BUSINESS_CITY=Curitiba
BUSINESS_TONE=proximo_descontraido   # profissional_cordial | proximo_descontraido | formal

# ── Aprovação (avaliações negativas) ─────────────────────────────────────────
APPROVAL_EMAIL=cliente@gmail.com

# ── SMTP para envio de e-mails (Gmail recomendado) ───────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # Senha de App do Gmail (não a senha normal)

# ── Servidor ──────────────────────────────────────────────────────────────────
APP_BASE_URL=https://seu-app.up.railway.app   # URL pública do serviço no Railway
PORT=8000
CHECK_INTERVAL_HOURS=2
AUTO_REPLY_MIN_RATING=4   # Avaliações >= este número são respondidas automaticamente
